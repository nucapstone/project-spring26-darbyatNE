{
  "name": "pjm-lmp-observable",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev:frontend": "observable preview --port 3000",
    "dev:backend": "uvicorn api.backend:app --reload --port 8000",
    "dev": "concurrently \"npm:dev:frontend\" \"npm:dev:backend\"",
    "clean": "rimraf src/.observablehq/cache",
    "build": "observable build",
    "build:demo-data": "python3 scripts/build_demo_snapshot.py",
    "build:docs": "npm run build && node -e \"const fs=require('fs'); fs.mkdirSync('docs/data/demo',{recursive:true}); fs.cpSync('src/data/demo','docs/data/demo',{recursive:true}); fs.writeFileSync('docs/.nojekyll','');\"",
    "deploy": "observable deploy",
    "observable": "observable"
  },
  "dependencies": {
    "@observablehq/plot": "^0.6.17",
    "@turf/turf": "^7.2.0",
    "d3": "^7.8.5",
    "maplibre-gl": "^4.0.0"
  },
  "devDependencies": {
    "@observablehq/framework": "^1.13.4",
    "concurrently": "^9.2.1",
    "rimraf": "^5.0.5"
  },
  "engines": {
    "node": ">=18"
  }
}
